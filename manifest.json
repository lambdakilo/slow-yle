{
  "manifest_version": 3,
  "name": "Unslop-yle",
  "version": "1.0",

  "description": "Un-slopify yle.fi",

  "browser_specific_settings": {
    "gecko": {
      "id": "unslopify@yle.lol",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["*://*.yle.fi/*"],
      "js": ["script.js"]
    }
  ]
}